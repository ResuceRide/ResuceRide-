@charset "utf-8";

:root { --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem); --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem); --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem); --text-lg: clamp(1.125rem, 1rem + 0.75vw, 1.5rem); --text-xl: clamp(1.5rem, 1.2rem + 1.25vw, 2rem); --text-2xl: clamp(2rem, 1.2rem + 2.5vw, 3rem); --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem; --space-5: 1.25rem; --space-6: 1.5rem; --space-8: 2rem; --space-10: 2.5rem; --space-12: 3rem; --space-16: 4rem; --color-bg: #f7f6f2; --color-surface: #ffffff; --color-surface-2: #f3f6f9; --color-border: #d6dce3; --color-text: #1d2733; --color-text-muted: #5c6773; --color-primary: #01696f; --color-primary-hover: #0c4e54; --color-primary-soft: #d9ecec; --color-warning: #da7101; --color-success: #2e7d32; --color-error: #b3261e; --radius-sm: 0.5rem; --radius-md: 0.75rem; --radius-lg: 1rem; --radius-xl: 1.25rem; --shadow-sm: 0 4px 12px rgba(0,0,0,0.06); --shadow-md: 0 10px 30px rgba(0,0,0,0.1); --font-body: 'Inter', sans-serif; }

* { box-sizing: border-box; margin: 0px; padding: 0px; }

html { scroll-behavior: smooth; }

body { min-height: 100vh; font-family: var(--font-body); font-size: var(--text-base); line-height: 1.6; background: linear-gradient(180deg, #eef5f5 0%, var(--color-bg) 100%); color: var(--color-text); }

a { color: inherit; text-decoration: none; }

img, svg { display: block; max-width: 100%; }

button, input, select, textarea { font: inherit; }

button { cursor: pointer; border: none; }

.container { width: min(1120px, 100% - 2rem); margin: 0px auto; }

.skip-link { position: absolute; left: -999px; top: 1rem; background: rgb(0, 0, 0); color: rgb(255, 255, 255); padding: 0.75rem 1rem; border-radius: 0.5rem; }

.skip-link:focus { left: 1rem; z-index: 999; }

header { position: sticky; top: 0px; z-index: 10; backdrop-filter: blur(12px); background: rgba(247, 246, 242, 0.88); border-bottom: 1px solid var(--color-border); }

.nav { display: flex; align-items: center; justify-content: space-between; min-height: 72px; gap: 1rem; }

.brand { display: flex; align-items: center; gap: 0.75rem; font-weight: 800; letter-spacing: 0.02em; }

.brand-mark { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; background: linear-gradient(135deg, var(--color-primary), #0b8f96); color: white; box-shadow: var(--shadow-sm); }

.nav-links { display: flex; gap: 1rem; flex-wrap: wrap; }

.nav-links a { padding: 0.6rem 0.85rem; border-radius: 999px; font-size: var(--text-sm); }

.nav-links a:hover { background: var(--color-primary-soft); color: var(--color-primary-hover); }

.hero { padding: clamp(2.5rem, 5vw, 5rem) 0px 2rem; display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 1.5rem; align-items: center; }

.hero-card, .panel, .service-card, .form-card, .status-card { background: rgba(255, 255, 255, 0.92); border: 1px solid rgba(29, 39, 51, 0.1); box-shadow: var(--shadow-sm); border-radius: var(--radius-xl); }

.hero-copy { padding: clamp(1.25rem, 3vw, 2.5rem); }

.eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; padding: 0.5rem 0.9rem; border-radius: 999px; background: var(--color-primary-soft); color: var(--color-primary-hover); font-size: var(--text-sm); font-weight: 700; }

h1 { font-size: var(--text-2xl); line-height: 1.08; margin-bottom: 1rem; }

.lead { color: var(--color-text-muted); max-width: 58ch; }

.hero-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 1.5rem; }

.btn { min-height: 46px; padding: 0.85rem 1.15rem; border-radius: 0.9rem; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; gap: 0.55rem; transition: 0.2s; }

.btn-primary { background: var(--color-primary); color: rgb(255, 255, 255); }

.btn-primary:hover { background: var(--color-primary-hover); }

.btn-secondary { background: rgb(255, 255, 255); color: var(--color-text); border: 1px solid var(--color-border); }

.btn-secondary:hover { background: var(--color-surface-2); }

.hero-visual { padding: 1rem; }

.map-mock { min-height: 360px; height: 100%; padding: 1.25rem; background: radial-gradient(circle at 20% 20%, rgba(1, 105, 111, 0.12), transparent 22%), radial-gradient(circle at 80% 30%, rgba(218, 113, 1, 0.12), transparent 18%), linear-gradient(135deg, rgb(255, 255, 255) 0%, rgb(238, 245, 245) 100%); border-radius: calc(var(--radius-xl) - .25rem); display: grid; align-content: space-between; gap: 1rem; }

.map-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }

.mini { padding: 1rem; border-radius: 1rem; background: rgba(255, 255, 255, 0.9); border: 1px solid rgba(29, 39, 51, 0.08); }

.mini strong { display: block; font-size: var(--text-lg); }

main { padding-bottom: 4rem; }

section { padding-top: 2rem; }

.section-head { margin-bottom: 1rem; }

.section-head h2 { font-size: var(--text-xl); margin-bottom: 0.4rem; }

.section-head p { color: var(--color-text-muted); }

.status-grid, .services-grid, .forms-grid { display: grid; gap: 1rem; }

.status-grid { grid-template-columns: repeat(4, 1fr); }

.services-grid { grid-template-columns: repeat(4, 1fr); }

.forms-grid { grid-template-columns: repeat(2, 1fr); }

.status-card, .service-card, .form-card { padding: 1.25rem; }

.status-card h3, .service-card h3, .form-card h3 { margin-bottom: 0.4rem; font-size: 1.15rem; }

.muted { color: var(--color-text-muted); }

.status-value { font-size: 1.1rem; font-weight: 700; margin-top: 0.35rem; }

.live-dot { width: 0.7rem; height: 0.7rem; border-radius: 50%; background: var(--color-success); display: inline-block; margin-right: 0.45rem; box-shadow: rgba(46, 125, 50, 0.12) 0px 0px 0px 6px; }

.service-card { display: flex; flex-direction: column; gap: 0.85rem; }

.service-icon { width: 52px; height: 52px; border-radius: 1rem; display: grid; place-items: center; background: var(--color-primary-soft); color: var(--color-primary-hover); font-size: 1.4rem; font-weight: 800; }

.tag { display: inline-flex; padding: 0.35rem 0.65rem; border-radius: 999px; background: rgb(255, 243, 232); color: rgb(155, 77, 0); font-size: 0.82rem; font-weight: 700; }

form { display: grid; gap: 0.9rem; }

.grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem; }

label { display: grid; gap: 0.4rem; font-weight: 600; font-size: var(--text-sm); }

input, select, textarea { width: 100%; min-height: 46px; padding: 0.85rem 0.95rem; border: 1px solid var(--color-border); border-radius: 0.85rem; background: rgb(255, 255, 255); color: var(--color-text); }

textarea { min-height: 110px; resize: vertical; }

input:focus, select:focus, textarea:focus { outline: rgba(1, 105, 111, 0.18) solid 2px; border-color: var(--color-primary); }

.inline-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.output { margin-top: 0.4rem; padding: 0.8rem 0.95rem; border-radius: 0.85rem; background: var(--color-surface-2); color: var(--color-text-muted); font-size: 0.95rem; }

.full { grid-column: 1 / -1; }

.sos { position: fixed; right: 1rem; bottom: 1rem; z-index: 15; min-width: 68px; min-height: 68px; border-radius: 999px; background: linear-gradient(135deg, rgb(239, 68, 68), rgb(185, 28, 28)); color: rgb(255, 255, 255); box-shadow: rgba(185, 28, 28, 0.28) 0px 14px 28px; font-weight: 800; }

footer { padding: 2.5rem 0px 4rem; color: var(--color-text-muted); }

@media (max-width: 980px) {
  .hero, .forms-grid, .status-grid, .services-grid { grid-template-columns: 1fr 1fr; }
  .hero { grid-template-columns: 1fr; }
}

@media (max-width: 720px) {
  .nav { flex-direction: column; align-items: flex-start; padding: 0.85rem 0px; }
  .nav-links { gap: 0.5rem; }
  .hero, .forms-grid, .status-grid, .services-grid, .grid-2, .map-grid { grid-template-columns: 1fr; }
  .container { width: min(100% - 1rem, 1120px); }
  .hero-actions, .inline-actions { flex-direction: column; }
  .btn { width: 100%; }
}
