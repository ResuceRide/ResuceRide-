@charset "utf-8";

:root { --bg: #f4f7fb; --surface: #ffffff; --surface-2: #eef3fb; --text: #18212f; --muted: #6a7688; --primary: #0d6efd; --primary-dark: #0a58ca; --danger: #dc3545; --warning: #ffb703; --success: #1f9d55; --info: #00b4d8; --border: #d9e2ef; --shadow: 0 18px 45px rgba(13, 110, 253, 0.12); --radius: 22px; }

* { box-sizing: border-box; }

body { margin: 0px; font-family: Inter, sans-serif; background: linear-gradient(rgb(237, 244, 255) 0%, rgb(248, 251, 255) 45%, rgb(238, 243, 251) 100%); color: var(--text); }

.topbar { position: sticky; top: 0px; z-index: 10; display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: rgba(13, 110, 253, 0.95); color: rgb(255, 255, 255); backdrop-filter: blur(8px); box-shadow: rgba(0, 0, 0, 0.12) 0px 8px 20px; }

.brand { display: flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: 0.2px; }

.brand-badge { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; background: rgba(255, 255, 255, 0.18); font-size: 20px; }

.nav-actions { display: flex; gap: 10px; align-items: center; }

.nav-btn { border: 1px solid rgba(255, 255, 255, 0.35); color: rgb(255, 255, 255); background: transparent; border-radius: 999px; padding: 10px 14px; cursor: pointer; font-weight: 600; }

.shell { max-width: 1180px; margin: 0px auto; padding: 24px 18px 56px; }

.hero { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 22px; align-items: stretch; margin-top: 10px; }

.hero-card, .panel, .service-card, .timeline-card, .form-card, .page-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); }

.hero-card { padding: 28px; }

.hero h1 { margin: 0px 0px 10px; font-size: clamp(2rem, 4vw, 3.7rem); line-height: 1.02; }

.hero p { color: var(--muted); font-size: 1rem; margin: 0px 0px 22px; max-width: 60ch; }

.hero-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 22px; }

.pill { padding: 10px 14px; border-radius: 999px; background: var(--surface-2); color: var(--text); font-size: 0.92rem; border: 1px solid var(--border); }

.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

.btn { border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 16px; padding: 14px 18px; cursor: pointer; font-weight: 700; font-size: 0.97rem; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 10px; }

.btn-primary { background: var(--primary); color: rgb(255, 255, 255); }

.btn-primary:hover { background: var(--primary-dark); }

.btn-light { background: var(--surface-2); color: var(--text); border: 1px solid var(--border); }

.btn-danger { background: var(--danger); color: rgb(255, 255, 255); }

.hero-side { display: grid; gap: 16px; }

.panel { padding: 22px; }

.panel h3, .section-title { margin: 0px 0px 14px; font-size: 1.2rem; }

.location-grid { display: grid; grid-template-columns: repeat(2, minmax(0px, 1fr)); gap: 12px; margin-top: 14px; }

.metric { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 14px; }

.metric span { display: block; font-size: 0.8rem; color: var(--muted); margin-bottom: 6px; }

.metric strong { font-size: 0.98rem; }

.live-dot { display: inline-flex; align-items: center; gap: 8px; font-weight: 700; color: var(--success); }

.live-dot::before { content: ""; width: 10px; height: 10px; border-radius: 50%; background: var(--success); box-shadow: rgba(31, 157, 85, 0.14) 0px 0px 0px 6px; animation: 1.5s ease 0s infinite normal none running pulse; }

@keyframes pulse { 
  0% { transform: scale(1); opacity: 1; }
  70% { transform: scale(1.18); opacity: 0.7; }
  100% { transform: scale(1); opacity: 1; }
}

.services-section { margin-top: 26px; }

.services-grid { display: grid; grid-template-columns: repeat(2, minmax(0px, 1fr)); gap: 16px; }

.service-card { padding: 22px; transition: transform 0.2s, box-shadow 0.2s; }

.service-card:hover { transform: translateY(-4px); box-shadow: rgba(0, 0, 0, 0.12) 0px 18px 40px; }

.service-icon { width: 60px; height: 60px; border-radius: 18px; display: grid; place-items: center; font-size: 24px; margin-bottom: 16px; color: rgb(255, 255, 255); }

.bg-mechanic { background: linear-gradient(135deg, rgb(13, 110, 253), rgb(58, 134, 255)); }

.bg-fuel { background: linear-gradient(135deg, rgb(255, 183, 3), rgb(251, 133, 0)); }

.bg-towing { background: linear-gradient(135deg, rgb(0, 180, 216), rgb(0, 119, 182)); }

.bg-battery { background: linear-gradient(135deg, rgb(42, 157, 143), rgb(31, 157, 85)); }

.service-card h3 { margin: 0px 0px 8px; }

.service-card p { margin: 0px 0px 14px; color: var(--muted); }

.service-meta { display: flex; gap: 16px; flex-wrap: wrap; color: var(--muted); font-size: 0.92rem; margin-bottom: 18px; }

.route-banner { margin-top: 22px; padding: 18px 20px; border-radius: 20px; background: linear-gradient(90deg, rgb(13, 110, 253), rgb(2, 62, 138)); color: rgb(255, 255, 255); display: flex; justify-content: space-between; gap: 16px; align-items: center; flex-wrap: wrap; }

.timeline-card, .form-card, .page-card { padding: 24px; margin-top: 22px; }

.timeline { display: grid; gap: 14px; }

.step { display: grid; grid-template-columns: 42px 1fr; gap: 14px; align-items: start; }

.step-badge { width: 42px; height: 42px; border-radius: 14px; background: var(--surface-2); border: 1px solid var(--border); display: grid; place-items: center; color: var(--primary); font-weight: 800; }

.auth-grid, .page-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 22px; }

.input-group { display: grid; gap: 8px; margin-bottom: 16px; }

.input-group label { font-weight: 600; }

.input-group input, .input-group select, .input-group textarea { width: 100%; padding: 14px; border-radius: 14px; border: 1px solid var(--border); background: rgb(255, 255, 255); font-size: 1rem; font-family: inherit; }

.input-group textarea { min-height: 110px; resize: vertical; }

.otp-row { display: flex; gap: 10px; }

.page-header { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; flex-wrap: wrap; }

.tag { display: inline-flex; align-items: center; gap: 8px; background: var(--surface-2); border: 1px solid var(--border); color: var(--muted); border-radius: 999px; padding: 8px 12px; font-size: 0.86rem; }

footer { text-align: center; color: var(--muted); padding: 30px 18px 48px; }

.mini-map { height: 220px; border-radius: 18px; overflow: hidden; border: 1px solid var(--border); background: linear-gradient(90deg, rgba(255, 255, 255, 0.4) 1px, transparent 1px) 0% 0% / 36px 36px, linear-gradient(rgba(255, 255, 255, 0.4) 1px, transparent 1px) 0% 0% / 36px 36px, linear-gradient(135deg, rgb(220, 238, 255), rgb(200, 222, 252)) 0% 0% / auto rgb(220, 238, 255); position: relative; }

.map-pin, .map-rider { position: absolute; width: 18px; height: 18px; border-radius: 50%; }

.map-pin { background: rgb(220, 53, 69); left: 58%; top: 36%; box-shadow: rgba(220, 53, 69, 0.15) 0px 0px 0px 10px; }

.map-rider { background: rgb(13, 110, 253); left: 35%; top: 62%; box-shadow: rgba(13, 110, 253, 0.14) 0px 0px 0px 10px; }

.map-line { position: absolute; left: 38%; top: 50%; width: 24%; height: 2px; background: repeating-linear-gradient(90deg, rgb(13, 110, 253) 0px, rgb(13, 110, 253) 10px, transparent 10px, transparent 16px); transform: rotate(-22deg); }

.small-note { font-size: 0.88rem; color: var(--muted); }

.hidden { display: none; }

@media (max-width: 900px) {
  .hero, .auth-grid, .page-grid, .services-grid { grid-template-columns: 1fr; }
  .location-grid { grid-template-columns: 1fr; }
  .topbar { padding: 14px; }
  .shell { padding: 18px 14px 42px; }
  .otp-row { flex-direction: column; }
}
